---
/*
  Features section — Bento Grid layout (dominant pattern 2025).
  Lead with BENEFITS not features. What does the user gain?
  Use the design principle: one idea per card.
*/

interface Feature {
  icon?: string;
  title: string;
  description: string;
  span?: 'default' | 'wide' | 'tall';
}

interface Props {
  eyebrow?: string;
  headline: string;
  features: Feature[];
}

const { eyebrow, headline, features } = Astro.props;
---

<section id="features" class="section">
  <div class="container">
    <div class="section__header">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 class="section__headline">{headline}</h2>
    </div>

    <div class="bento">
      {features.map((f) => (
        <div class={`bento__card bento__card--${f.span ?? 'default'}`}>
          {f.icon && <span class="bento__icon" aria-hidden="true">{f.icon}</span>}
          <h3 class="bento__title">{f.title}</h3>
          <p class="bento__desc">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .bento__card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .bento__card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .bento__card--wide {
    grid-column: span 2;
  }

  .bento__card--tall {
    grid-row: span 2;
  }

  .bento__icon {
    font-size: 1.75rem;
    line-height: 1;
  }

  .bento__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .bento__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .bento {
      grid-template-columns: 1fr;
    }

    .bento__card--wide,
    .bento__card--tall {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>
