---
/*
  Hero — the most important section on the page.
  Follows the PAS (Problem → Agitate → Solve) framework for copy.

  COPY GUIDELINES (from B2B outreach skill):
  - Headline: name the painful problem or the desired outcome. Not a question. No buzzwords.
  - Subheadline: agitate the gap between where they are and where they want to be.
  - CTA: one primary action, action-oriented verb. Never "Submit" or "Click here".
  - Social proof teaser: a number or logo strip under the CTA (credibility before the scroll).
*/

interface Props {
  badge?: string;
  headline: string;
  subheadline: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  socialProof?: string;
}

const {
  badge,
  headline,
  subheadline,
  ctaPrimary = { label: 'Get started free', href: '#contact' },
  ctaSecondary,
  socialProof,
} = Astro.props;
---

<section class="hero">
  <div class="hero__inner">
    {badge && <span class="badge">{badge}</span>}

    <h1 class="hero__headline">{headline}</h1>
    <p class="hero__sub">{subheadline}</p>

    <div class="hero__ctas">
      <a href={ctaPrimary.href} class="btn btn--primary btn--lg">{ctaPrimary.label}</a>
      {ctaSecondary && (
        <a href={ctaSecondary.href} class="btn btn--ghost btn--lg">{ctaSecondary.label}</a>
      )}
    </div>

    {socialProof && (
      <p class="hero__proof">{socialProof}</p>
    )}
  </div>
</section>

<style>
  .hero {
    padding: var(--space-section) var(--space-content);
    text-align: center;
  }

  .hero__inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.875rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    background-color: var(--color-surface);
  }

  .hero__headline {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-primary);
    margin: 0;
    max-width: 680px;
  }

  .hero__sub {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin: 0;
    max-width: 560px;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero__proof {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
