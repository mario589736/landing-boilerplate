---
/*
  Final CTA section — placed at bottom before footer.
  Mirror the hero's value promise. Reinforce the primary action.
  Keep it simple: headline + one button + optional risk-reducer (no cc required, etc.)
*/

interface Props {
  headline: string;
  subheadline?: string;
  ctaLabel?: string;
  ctaHref?: string;
  riskReducer?: string;
}

const {
  headline,
  subheadline,
  ctaLabel = 'Get started free',
  ctaHref = '#contact',
  riskReducer = 'No credit card required.',
} = Astro.props;
---

<section class="cta-section">
  <div class="container container--narrow cta-section__inner">
    <h2 class="cta-section__headline">{headline}</h2>
    {subheadline && <p class="cta-section__sub">{subheadline}</p>}
    <a href={ctaHref} class="btn btn--primary btn--lg">{ctaLabel}</a>
    {riskReducer && <p class="cta-section__risk">{riskReducer}</p>}
  </div>
</section>

<style>
  .cta-section {
    padding: var(--space-section) var(--space-content);
    background: linear-gradient(
      135deg,
      color-mix(in oklch, var(--color-interactive) 12%, var(--color-bg)),
      var(--color-bg)
    );
    border-top: 1px solid var(--color-border);
  }

  .cta-section__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .cta-section__headline {
    font-size: var(--text-3xl);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--color-text-primary);
    margin: 0;
  }

  .cta-section__sub {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 480px;
  }

  .cta-section__risk {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
